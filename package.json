{
  "name": "shunban",
  "version": "0.1.0",
  "description": "顺办：面向内网的个人工作流程备忘系统",
  "private": true,
  "license": "MIT",
  "repository": "https://github.com/AlisterTT/shunban",
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:web\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:server": "node --watch server/index.js",
    "setup": "node scripts/setup.mjs",
    "deploy": "node scripts/setup.mjs --start",
    "db:init": "node scripts/init-db.mjs",
    "db:backup": "node scripts/backup-db.mjs",
    "db:reset": "node scripts/reset-db.mjs",
    "demo:db": "node scripts/create-demo-db.mjs",
    "test:smoke": "node scripts/review-smoke.mjs",
    "build": "vite build",
    "start": "node server/index.js --production"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.3",
    "@xyflow/react": "12.11.2",
    "concurrently": "10.0.3",
    "express": "5.2.1",
    "lucide-react": "1.24.0",
    "vite": "8.1.4",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {}
}
